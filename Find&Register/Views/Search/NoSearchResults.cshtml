@model SearchResultsModel
@inject NonceModel Nonces
<link rel="stylesheet" href="/css/accessible-autocomplete.min.css">
@section Scripts {
    <script nonce="@Nonces.GaNonce" type="text/javascript" src="/js/accessible-autocomplete.min.js" style-src='self'>
    </script>
}
<script nonce="@Nonces.GaNonce" type="text/javascript">
    var countries = [];
    @if (Model.LocationModels != null) @foreach (var location in Model.LocationModels.OrderBy(la => la.LocalAuthority))
    {
        @:countries.push("@location.LocalAuthority");
    }
</script>

<script nonce="@Nonces.GaNonce" type="text/javascript">
    document.addEventListener("DOMContentLoaded", function () {
        var element = document.querySelector('#tt-default')
        var id = 'Area'
        accessibleAutocomplete({
            element: element,
            id: id,
            source: countries
        })
    }) 
</script>
<div class="govuk-width-container ">
    <a href="@Url.Action("Index", "Search")" class="govuk-back-link">Back</a>
    <main class="govuk-main-wrapper govuk-main-wrapper--auto-spacing" id="main-content" role="main">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
                <h1 class="govuk-fieldset__heading">
                    We cannot find any organisations selling shared ownership homes in @Model.Area
                </h1>
            </legend>
            <p>
                You may still be able to find a shared ownership home by contacting City Council.  
            </p>
            <p>
                City Council can tell you about shared ownership homes not included in this service.
            </p>

            @{var cousil = Model?.ProviderModels?.Where(x=>x.IsLocalAuthority == true).FirstOrDefault();}
            <h2 class="govuk-heading-s">Contact  City Council</h2>
            <p class="govuk-body"><span class="govuk-!-font-weight-bold">Telephone:</span> @cousil?.Phone</p>
            <p class="govuk-body"><span class="govuk-!-font-weight-bold">Email:</span> <a href="mailto:@cousil?.Email">@cousil?.Email</a></p>
            @* <p class="govuk-body"><span class="govuk-!-font-weight-bold">Address:</span> @cousil. 1 High Street, , AB1 1BC</p> *@
            <p class="govuk-body"><span class="govuk-!-font-weight-bold">Website:</span> <a href="@cousil?.WebsiteUrl">@cousil?.Website</a></p>

            <form action="@Url.Action("SearchResults", "Search")" method="post" autocomplete="off">
                <div class="govuk-form-group">
                    <h3 class="govuk-label-wrapper"><label class="govuk-label govuk-label--m" for="searchArea">
              Search again
            </label>
          </h3>
                    <div id="searchArea-container">
                        <div id="tt-default" class="autocomplete-wrapper">
                            <div class="autocomplete__wrapper">
                                <div>
                                    <div id="@Model?.Area" name="@Model?.Area"
                                        role="status" aria-atomic="true"
                                        aria-live="polite">
                                    </div>
                                </div>
                                <ul class="autocomplete__menu autocomplete__menu--inline autocomplete__menu--hidden"
                                    id="autocomplete-default__listbox"
                                    role="listbox"></ul>
                                <span id="autocomplete-default__assistiveHint" />
                            </div>
                        </div>
                    </div>
                </div>
                <button class="govuk-button" data-module="govuk-button">
                    Search
                </button>
            </form>
                
            </div>
        </div>
    </main>
</div>