@model EligibilityJourneyFirstTimeBuyer
@{
    ViewBag.Title = "First time buyer";
    var FirstTimeBuyer = nameof(EligibilityJourneyFirstTimeBuyer.firstTimeBuyer);
    var OwnAHomeButNeedToMove = nameof(EligibilityJourneyFirstTimeBuyer.ownAHomeButNeedToMove);
    var CannotAffordAHome = nameof(EligibilityJourneyFirstTimeBuyer.cannotAffordAHome);
    var TheseDoNotApply = nameof(EligibilityJourneyFirstTimeBuyer.theseDoNotApply);
}
@*<input class="govuk-checkboxes__input" id="first-time-buyer" name="current-circumstances" type="checkbox" value="First time buyer">*@

<div class="govuk-width-container ">
    <a href="@ViewBag.previousPage" class="govuk-back-link">Back</a>
    <main class="govuk-main-wrapper govuk-main-wrapper--auto-spacing" id="main-content" role="main">
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                @if ((ViewContext.HttpContext.Items["errorsBool"] as bool?) == true)@await Html.PartialAsync("_ErrorSummary", ViewContext.HttpContext.Items["errors"])
                <form method="post">
                    @await Html.PartialAsync("_GovFormGroupValidation", new GovukValidatedFormFieldModel
               {
                   HtmlId = FirstTimeBuyer,
                   //ValidationMessage = Html.ValidationMessageFor(m => m.FirstTimeBuyer),
                   AriaDescribe = FirstTimeBuyer + "-error",
                   Errors = ViewContext.HttpContext.Items["errors"] as IList<ErrorSummary>,
                   Title = "Select all that apply to you",
                   Content =
                                                    @<div class="govuk-form-group">
                                                        <fieldset class="govuk-fieldset">
                                                            <div class="govuk-checkboxes" data-module="govuk-checkboxes">

                                                                @*@Html.CheckBox("firstTimeBuyer", false)*@
                                                                @*<label class="govuk-label govuk-checkboxes__label" asp-for="@FirstTimeBuyer" name="@FirstTimeBuyer">*@
                                                                @*@Html.CheckBoxFor(m => m.firstTimeBuyer, new { @class = "govuk-checkboxes__input" })
                                                                <label for="firstTimeBuyer" class="govuk-label govuk-checkboxes__label" style="display:inline">Include completed</label>*@

                                                                <div class="govuk-checkboxes__item">
                                                                    <input class="govuk-checkboxes__input" id="first-time-buyer" name="@FirstTimeBuyer" type="checkbox" value="true">
                                                                    <label class="govuk-label govuk-checkboxes__label" for="first-time-buyer">
                                                                        I am a first time buyer
                                                                    </label>
                                                                </div>
                                                                <div class="govuk-checkboxes__item">
                                                                    <input class="govuk-checkboxes__input" id="own-a-home" name="@OwnAHomeButNeedToMove" type="checkbox" value="true">
                                                                    <label class="govuk-label govuk-checkboxes__label" for="own-a-home">
                                                                        I own a home but need to move
                                                                    </label>
                                                                </div>
                                                                <div class="govuk-checkboxes__item">
                                                                    <input class="govuk-checkboxes__input" id="cannot-afford-home" name="@CannotAffordAHome" type="checkbox" value="true">
                                                                    <label class="govuk-label govuk-checkboxes__label" for="cannot-afford-home">
                                                                        I cannot afford a home unless I use shared ownership
                                                                    </label>
                                                                </div>
                                                                <div class="govuk-checkboxes__divider">or</div>
                                                                <div class="govuk-checkboxes__item">
                                                                    <input class="govuk-checkboxes__input" id="none" name="@TheseDoNotApply" type="checkbox" value="true" data-behaviour="exclusive">
                                                                    <label class="govuk-label govuk-checkboxes__label" for="none">
                                                                        These do not apply to me
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </fieldset>
                                                    </div>
})
                    <button class="govuk-button" id="eligibility-Page-4-Submit-Button" data-module="govuk-button" type="submit">
                        Continue
                    </button>
                </form>
            </div>
        </div>
    </main>
</div>