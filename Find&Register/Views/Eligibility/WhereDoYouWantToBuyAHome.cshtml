@model EligibilityWhereDoYouWantToBuyAHomePage
@{
    ViewBag.Title = "Where do you want to buy a home";
    var LivingLocation = nameof(EligibilityWhereDoYouWantToBuyAHomePage.LivingLocation);
}

<div class="govuk-width-container">
    <a href="@ViewBag.previousPage" class="govuk-back-link">Back</a>
    <main class="govuk-main-wrapper">
        @if ((ViewContext.HttpContext.Items["errorsBool"] as bool?) == true)@await Html.PartialAsync("_ErrorSummary", ViewContext.HttpContext.Items["errors"])
        <form method="post">
            @await Html.PartialAsync("_GovFormGroupValidation", new GovukValidatedFormFieldModel
            {
               HtmlId = LivingLocation,
               ValidationMessage = Html.ValidationMessageFor(m => m.LivingLocation),
               AriaDescribe = LivingLocation + "-error",
               Errors = ViewContext.HttpContext.Items["errors"] as IList<ErrorSummary>,
               Title = "Where do you want to buy a home?",
               Content =
                                            @<div class="govuk-form-group">
                                                <fieldset class="govuk-fieldset">
                                                    <div class="govuk-radios" data-module="govuk-radios">
                                                        <div class="govuk-radios__item">
                                                            <input class="govuk-radios__input" id="WhereDoYouWantToBuyAHome" asp-for="@LivingLocation" name="@LivingLocation"
                                                                   type="radio" value=true>
                                                            <label class="govuk-label govuk-radios__label" for="WhereDoYouWantToBuyAHome">
                                                                London
                                                            </label>
                                                        </div>
                                                        <div class="govuk-radios__item">
                                                            <input class="govuk-radios__input" id="WhereDoYouWantToBuyAHome2" asp-for="@LivingLocation" name="@LivingLocation"
                                                                   type="radio" value=false>
                                                            <label class="govuk-label govuk-radios__label" for="WhereDoYouWantToBuyAHome2">
                                                                Somewhere else
                                                            </label>
                                                        </div>
                                                    </div>
                                                </fieldset>
                                            </div>
})
            <button class="govuk-button" id="submitButton" data-module="govuk-button" type="submit">
                Continue
            </button>
        </form>
    </main>
</div>
